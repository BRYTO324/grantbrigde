DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Neon / Supabase / Railway PostgreSQL)
DATABASE_URL=postgres://user:password@host:5432/grantbridge

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=GrantBridge <your@gmail.com>

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxx
FLUTTERWAVE_ENCRYPTION_KEY=xxxx
FLUTTERWAVE_WEBHOOK_SECRET=your-webhook-secret

# Redis
REDIS_URL=redis://localhost:6379/0

# Platform
FRONTEND_URL=http://localhost:3000
PLATFORM_COMMISSION_RATE=0.07

# CORS - Add your production frontend domain here (comma-separated)
# Example: CORS_ALLOWED_ORIGINS=http://localhost:5173,https://grantbridge.vercel.app,https://www.grantbridge.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
